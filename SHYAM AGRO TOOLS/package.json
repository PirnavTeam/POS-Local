{
  "name": "augro",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@craco/craco": "^7.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "autoprefixer": "^10.4.16",
    "axios": "^1.16.1",
    "concurrently": "^9.2.1",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "lottie-web": "^5.13.0",
    "lucide-react": "^1.16.0",
    "postcss": "^8.4.31",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.2",
    "react-scripts": "5.0.1",
    "recharts": "^3.8.1",
    "swiper": "^12.1.4",
    "tailwindcss": "^3.4.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "dev": "set PORT=3001 && npm start",
    "start": "concurrently \"npm run watch:css\" \"craco start\"",
    "watch:css": "tailwindcss -i ./src/index.css -o ./src/tailwind-output.css --watch",
    "build:css": "tailwindcss -i ./src/index.css -o ./src/tailwind-output.css",
    "build": "npm run build:css && craco build",
    "test": "craco test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
